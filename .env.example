# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here
SCAN_INTERVAL_MINUTES=5
COOLDOWN_MINUTES=30

# ThetaData Terminal (real-time data) — runs inside the container
THETA_EMAIL=you@example.com
THETA_PASSWORD=your_thetadata_password
# Host path to ThetaData's jar on the droplet (mounted into the container, NOT in the repo)
THETA_JAR_HOST=/root/ThetaTerminal.jar
